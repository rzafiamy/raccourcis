{
  "name": "raccourcis",
  "version": "1.3.0",
  "description": "Powerful shortcuts and AI workflows for Ubuntu Linux",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder",
    "preview": "vite preview",
    "release": "./scripts/release.sh"
  },
  "keywords": [
    "shortcut",
    "automation",
    "workflow",
    "ai",
    "electron"
  ],
  "author": "rzafiamy",
  "license": "Apache-2.0",
  "devDependencies": {
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3",
    "vite": "^5.2.8",
    "vite-plugin-electron": "^0.28.4",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "dependencies": {
    "docx": "^9.6.1",
    "fast-xml-parser": "^5.5.11",
    "js-yaml": "^4.1.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "openai": "^6.34.0",
    "pptxgenjs": "^4.0.1",
    "systeminformation": "^5.31.5",
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.rzafiamy.raccourcis",
    "productName": "Raccourcis",
    "directories": {
      "output": "release/${version}"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    },
    "publish": {
      "provider": "github",
      "owner": "rzafiamy",
      "repo": "raccourcis"
    }
  }
}
